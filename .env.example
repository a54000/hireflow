# Gemini API key used for AI screening and JD/CV matching
GEMINI_API_KEY=

# Force Gemini for JD/CV parsing when available
PARSE_LLM_PROVIDER=gemini

# Maximum number of Gemini screening calls allowed at once
GEMINI_SCREENING_ACTIVE_LIMIT=5

# How many retry attempts to make before giving up on a Gemini call
GEMINI_RETRY_ATTEMPTS=3
GEMINI_RETRY_ATTEMPTS_503=5

# General retry backoff for non-503 Gemini errors
GEMINI_RETRY_BASE_DELAY_SECONDS=2.0
GEMINI_RETRY_MAX_DELAY_SECONDS=30.0

# Slower retry backoff for 503 / high-demand spikes
GEMINI_503_BASE_DELAY_SECONDS=5.0
GEMINI_503_MAX_DELAY_SECONDS=60.0

# Gemini models to try in order when the primary model is overloaded
GEMINI_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_FALLBACK=gemini-1.5-flash

# Wait before re-queueing retryable AI screening tasks
GEMINI_SCREENING_RETRY_DELAY_SECONDS=60
GEMINI_SCREENING_RETRY_MAX_ATTEMPTS=2

# How long to pause Gemini after quota/rate-limit exhaustion
GEMINI_CIRCUIT_COOLDOWN_SECONDS=120
